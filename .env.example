# DATABASE
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_NAME=idp_dev

# CACHE
REDIS_PORT=6379
REDIS_HOST=localhost

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production

# ENCRYPTION (base64-encoded 32-byte key — generate with: openssl rand -base64 32)
ENCRYPTION_KEY=
JWT_ISSUER=idp-backend
JWT_AUDIENCE=idp-users
ACCESS_TOKEN_TTL=15
REFRESH_TOKEN_TTL=10080

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_CALLBACK_URL=http://localhost:3000/api/v1/auth/gitlab/callback

# API
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# LOGGING
LOG_LEVEL=info
